<script>
  let secret, lo, hi, steps, active = false;

  function startGame() {
    secret = Math.floor(Math.random() * 1000) + 1;
    lo = 1; hi = 1000; steps = 0; active = true;
    const log = document.getElementById('gameLog');
    log.innerHTML = '';
    log.style.display = 'block';
    document.getElementById('guessRow').style.display = 'flex';
    document.getElementById('stepsDisplay').style.display = '';
    nextGuess();
  }

  function nextGuess() {
    const mid = Math.floor((lo + hi) / 2);
    document.getElementById('computerGuess').textContent = mid;
    document.getElementById('stepNum').textContent = steps + 1;
    document.getElementById('loVal').textContent = lo;
    document.getElementById('hiVal').textContent = hi;
  }

  function respond(result) {
    if (!active) return;
    const mid = Math.floor((lo + hi) / 2);
    const log = document.getElementById('gameLog');
    steps++;

    if (result === 'win') {
      active = false;
      log.innerHTML += `<div class="log-win">✓ Trovato! Il numero era ${mid}. Ci ho messo ${steps} tentativi.</div>`;
      document.getElementById('guessRow').style.display = 'none';
      return;
    }

    if (result === 'low') {
      log.innerHTML += `<div class="log-lo">Tentativo ${steps}: propongo ${mid} → troppo basso → nuovo intervallo [${mid+1}, ${hi}]</div>`;
      lo = mid + 1;
    } else {
      log.innerHTML += `<div class="log-hi">Tentativo ${steps}: propongo ${mid} → troppo alto → nuovo intervallo [${lo}, ${mid-1}]</div>`;
      hi = mid - 1;
    }

    if (lo > hi) {
      log.innerHTML += `<div class="log-win">Attenzione: le risposte non sono consistenti!</div>`;
      active = false;
      document.getElementById('guessRow').style.display = 'none';
      return;
    }

    log.scrollTop = log.scrollHeight;
    nextGuess();
  }
</script>
