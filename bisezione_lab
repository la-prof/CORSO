<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Metodo di Bisezione — Lab Python</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Fraunces:ital,wght@0,300;0,700;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface2: #1c2330;
    --border: #30363d;
    --accent: #58a6ff;
    --accent2: #3fb950;
    --accent3: #f78166;
    --accent4: #e3b341;
    --text: #e6edf3;
    --muted: #8b949e;
    --code-bg: #0d1117;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 300;
    line-height: 1.7;
    min-height: 100vh;
  }

  /* ── Header ── */
  header {
    border-bottom: 1px solid var(--border);
    padding: 2.5rem 3rem 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .header-left .kicker {
    font-family: 'JetBrains Mono', monospace;
    font-size: .72rem;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: .4rem;
  }

  header h1 {
    font-size: 2.4rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -.02em;
  }

  header h1 span { color: var(--accent); }

  .header-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: .75rem;
    color: var(--muted);
    text-align: right;
    line-height: 1.8;
  }

  /* ── Layout ── */
  main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 2rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ── Section card ── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: .9rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface2);
  }

  .badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: .7rem;
    font-weight: 600;
    padding: .2rem .6rem;
    border-radius: 4px;
    letter-spacing: .08em;
    flex-shrink: 0;
  }

  .badge-blue  { background: #1c3a5e; color: var(--accent); }
  .badge-green { background: #1a3a25; color: var(--accent2); }
  .badge-red   { background: #3a1c1a; color: var(--accent3); }
  .badge-gold  { background: #3a2d0f; color: var(--accent4); }

  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -.01em;
  }

  .card-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: .7rem;
    color: var(--muted);
    margin-left: auto;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  /* ── Intro box ── */
  .intro-box {
    background: linear-gradient(135deg, #1c3a5e44, #1a3a2544);
    border: 1px solid #30363d;
    border-left: 3px solid var(--accent);
    border-radius: 6px;
    padding: 1rem 1.2rem;
    font-size: .95rem;
    font-style: italic;
    color: #c9d1d9;
  }

  /* ── Steps ── */
  .steps { display: flex; flex-direction: column; gap: .8rem; }

  .step {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .step-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: .8rem;
    font-weight: 700;
    color: var(--accent);
    background: #1c3a5e;
    border-radius: 50%;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: .15rem;
  }

  .step-content { font-size: .95rem; }
  .step-content strong { color: var(--text); font-weight: 700; }

  /* ── Code block ── */
  .code-block {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .code-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: .7rem;
    color: var(--muted);
    padding: .5rem 1rem;
    border-bottom: 1px solid var(--border);
    background: #161b22;
    letter-spacing: .05em;
  }

  pre {
    font-family: 'JetBrains Mono', monospace;
    font-size: .82rem;
    line-height: 1.7;
    padding: 1.1rem 1.2rem;
    overflow-x: auto;
  }

  .kw  { color: #ff7b72; }
  .fn  { color: #d2a8ff; }
  .st  { color: #a5d6ff; }
  .cm  { color: #8b949e; font-style: italic; }
  .nb  { color: #79c0ff; }
  .op  { color: #ff7b72; }
  .num { color: #f8c555; }
  .var { color: #e6edf3; }

  /* ── Table ── */
  .table-wrap { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'JetBrains Mono', monospace;
    font-size: .82rem;
  }

  th {
    background: var(--surface2);
    color: var(--accent);
    font-weight: 600;
    padding: .6rem .9rem;
    text-align: left;
    border-bottom: 2px solid var(--border);
    letter-spacing: .05em;
    font-size: .72rem;
    text-transform: uppercase;
  }

  td {
    padding: .55rem .9rem;
    border-bottom: 1px solid var(--border);
    color: var(--muted);
    font-size: .82rem;
  }

  td.fill {
    color: transparent;
    background: repeating-linear-gradient(
      -45deg, #21262d, #21262d 3px, #161b22 3px, #161b22 7px
    );
    border-radius: 4px;
    user-select: none;
  }

  tr:last-child td { border-bottom: none; }

  /* ── Question list ── */
  .questions { display: flex; flex-direction: column; gap: .7rem; }

  .question {
    display: flex;
    gap: .7rem;
    align-items: flex-start;
    font-size: .92rem;
  }

  .q-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: .75rem;
    color: var(--accent4);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: .15rem;
  }

  .answer-line {
    display: block;
    border-bottom: 1px dashed #30363d;
    margin-top: .4rem;
    height: 1.4rem;
    width: 100%;
  }

  /* ── Highlight box ── */
  .highlight-box {
    border: 1px dashed #3fb950;
    border-radius: 8px;
    padding: 1rem 1.2rem;
    background: #1a3a2520;
  }

  .highlight-box .hl-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: .7rem;
    color: var(--accent2);
    letter-spacing: .12em;
    text-transform: uppercase;
    margin-bottom: .5rem;
    font-weight: 700;
  }

  .highlight-box p { font-size: .93rem; }

  /* ── Challenge box ── */
  .challenge-box {
    border: 1px solid #e3b34140;
    border-radius: 8px;
    padding: 1rem 1.2rem;
    background: #3a2d0f18;
  }

  .challenge-box .ch-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: .7rem;
    color: var(--accent4);
    letter-spacing: .12em;
    text-transform: uppercase;
    margin-bottom: .5rem;
    font-weight: 700;
  }

  .challenge-box ul {
    padding-left: 1.2rem;
    font-size: .9rem;
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }

  /* ── Theorem card ── */
  .theorem {
    border: 1px solid #58a6ff40;
    border-radius: 8px;
    padding: 1.1rem 1.3rem;
    background: #1c3a5e18;
    font-size: .93rem;
  }

  .theorem .th-name {
    font-family: 'JetBrains Mono', monospace;
    font-size: .7rem;
    color: var(--accent);
    letter-spacing: .12em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: .4rem;
  }

  .math {
    font-family: 'JetBrains Mono', monospace;
    font-size: .88rem;
    color: #a5d6ff;
  }

  /* ── Footer ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 1.2rem 3rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: .68rem;
    color: var(--muted);
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: .5rem;
  }

  /* ── Animated entrance ── */
  .card {
    opacity: 0;
    transform: translateY(18px);
    animation: fadeUp .5s ease forwards;
  }

  .card:nth-child(1) { animation-delay: .05s; }
  .card:nth-child(2) { animation-delay: .15s; }
  .card:nth-child(3) { animation-delay: .25s; }
  .card:nth-child(4) { animation-delay: .35s; }
  .card:nth-child(5) { animation-delay: .45s; }

  @keyframes fadeUp {
    to { opacity: 1; transform: none; }
  }

  /* ── Interactive game ── */
  .game-area {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .game-row {
    display: flex;
    align-items: center;
    gap: .8rem;
    flex-wrap: wrap;
  }

  .game-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: .78rem;
    color: var(--muted);
    min-width: 80px;
  }

  .game-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    min-width: 60px;
  }

  .game-input {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    font-family: 'JetBrains Mono', monospace;
    font-size: .9rem;
    padding: .4rem .8rem;
    width: 120px;
    outline: none;
    transition: border-color .2s;
  }

  .game-input:focus { border-color: var(--accent); }

  .btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: .45rem 1rem;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    transition: opacity .15s, transform .1s;
  }

  .btn:active { transform: scale(.97); }
  .btn:hover  { opacity: .85; }

  .btn-blue  { background: var(--accent); color: #0d1117; }
  .btn-green { background: var(--accent2); color: #0d1117; }
  .btn-red   { background: var(--accent3); color: #0d1117; }

  .game-log {
    font-family: 'JetBrains Mono', monospace;
    font-size: .78rem;
    color: var(--muted);
    background: #0a0d12;
    border-radius: 6px;
    padding: .8rem 1rem;
    min-height: 60px;
    max-height: 160px;
    overflow-y: auto;
    line-height: 1.9;
    display: none;
  }

  .log-ok  { color: var(--accent2); }
  .log-lo  { color: var(--accent4); }
  .log-hi  { color: var(--accent3); }
  .log-win { color: var(--accent); font-weight: 700; }

  .game-steps-count {
    font-family: 'JetBrains Mono', monospace;
    font-size: .75rem;
    color: var(--muted);
  }

  .game-steps-count span { color: var(--accent4); font-weight: 700; }
</style>
</head>
<body>

<header>
  <div class="header-left">
    <div class="kicker">Laboratorio Python · 5ª Liceo Scienze Applicate</div>
    <h1>Metodo di<br><span>Bisezione</span></h1>
  </div>
  <div class="header-meta">
    Attività individuale<br>
    Durata stimata: 50 min<br>
    Prerequisiti: funzioni, cicli, if
  </div>
</header>

<main>

  <!-- ── FASE 0: warm-up ── -->
  <div class="card">
    <div class="card-header">
      <span class="badge badge-blue">FASE 1</span>
      <span class="card-title">Il gioco "Indovina il numero"</span>
      <span class="card-time">⏱ 8 min</span>
    </div>
    <div class="card-body">

      <div class="intro-box">
        Prima di scrivere una riga di codice, giochiamo. Il computer ha scelto un numero intero
        segreto tra 1 e 1000. Tu devi trovarlo nel minor numero di tentativi possibile.
      </div>

      <!-- Interactive game -->
      <div class="game-area">
        <div class="game-row">
          <button class="btn btn-green" onclick="startGame()">▶ NUOVA PARTITA</button>
          <span class="game-steps-count" id="stepsDisplay" style="display:none">
            Tentativo n. <span id="stepNum">0</span> &nbsp;|&nbsp; Intervallo: [<span id="loVal">1</span>, <span id="hiVal">1000</span>]
          </span>
        </div>

        <div class="game-row" id="guessRow" style="display:none">
          <span class="game-label">La mia guess:</span>
          <span class="game-value" id="computerGuess">—</span>
          <button class="btn btn-blue" onclick="respond('low')" title="Il numero segreto è più grande">⬆ TROPPO BASSO</button>
          <button class="btn btn-red"  onclick="respond('high')" title="Il numero segreto è più piccolo">⬇ TROPPO ALTO</button>
          <button class="btn btn-green" onclick="respond('win')">✓ ESATTO!</button>
        </div>

        <div class="game-log" id="gameLog"></div>
      </div>

      <div class="questions">
        <div class="question">
          <span class="q-num">Q1.</span>
          <div>
            Quanti tentativi ha impiegato il computer? <strong>______</strong>
            &nbsp; Era più o meno di quanto ti aspettavi? <strong>______________________</strong>
            <span class="answer-line"></span>
          </div>
        </div>
        <div class="question">
          <span class="q-num">Q2.</span>
          <div>
            Guarda il log: noti una strategia precisa nel modo in cui il computer sceglie il numero?
            Descrivila con parole tue.
            <span class="answer-line"></span>
            <span class="answer-line"></span>
          </div>
        </div>
        <div class="question">
          <span class="q-num">Q3.</span>
          <div>
            Nel <em>caso peggiore</em>, quanti tentativi servono al massimo per trovare un numero tra 1 e 1000?
            Prova a stimarlo senza calcolarlo — poi verifica. <strong>Stima: ______&nbsp;&nbsp; Verifica: ______</strong>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ── FASE 2: dal gioco al metodo ── -->
  <div class="card">
    <div class="card-header">
      <span class="badge badge-green">FASE 2</span>
      <span class="card-title">Dal gioco alla matematica</span>
      <span class="card-time">⏱ 10 min</span>
    </div>
    <div class="card-body">

      <div class="theorem">
        <div class="th-name">Teorema degli zeri (Bolzano)</div>
        Se <span class="math">f</span> è continua su <span class="math">[a, b]</span>
        e <span class="math">f(a) · f(b) &lt; 0</span>,
        allora esiste almeno un <span class="math">c ∈ (a, b)</span> tale che <span class="math">f(c) = 0</span>.
      </div>

      <p style="font-size:.93rem">
        Il gioco che hai appena giocato <em>è esattamente</em> questo teorema in azione.
        La funzione nascosta era <span class="math" style="font-family:'JetBrains Mono',monospace; color:#a5d6ff">f(x) = x − segreto</span>.
        L'obiettivo era trovare lo zero di <span class="math" style="font-family:'JetBrains Mono',monospace; color:#a5d6ff">f</span>.
      </p>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Iterazione</th>
              <th>a (estremo sinistro)</th>
              <th>b (estremo destro)</th>
              <th>m = (a+b)/2</th>
              <th>f(m)</th>
              <th>Prossimo intervallo</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>0</td>
              <td>1</td>
              <td>1000</td>
              <td>500</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
            </tr>
            <tr>
              <td>1</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
            </tr>
            <tr>
              <td>2</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
            </tr>
            <tr>
              <td>3</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
              <td class="fill">███</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p style="font-size:.85rem; color: var(--muted); font-family:'JetBrains Mono',monospace">
        ↑ Completa la tabella per <span style="color:var(--accent4)">f(x) = x² − 2</span>
        sull'intervallo <span style="color:var(--accent)"> [1, 2]</span> (approssimazione di √2).
        Ferma l'algoritmo quando b − a &lt; 0.01.
      </p>

      <div class="questions">
        <div class="question">
          <span class="q-num">Q4.</span>
          <div>
            Ad ogni passo, di quanto si riduce l'ampiezza dell'intervallo?
            <span class="answer-line"></span>
          </div>
        </div>
        <div class="question">
          <span class="q-num">Q5.</span>
          <div>
            Quante iterazioni servono per avere un errore massimo inferiore a <span class="math" style="font-family:'JetBrains Mono',monospace">ε = 10⁻⁶</span>
            partendo da <span class="math" style="font-family:'JetBrains Mono',monospace">[1, 2]</span>?
            <em>(Suggerimento: usa i logaritmi.)</em>
            <span class="answer-line"></span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ── FASE 3: codice ── -->
  <div class="card">
    <div class="card-header">
      <span class="badge badge-red">FASE 3</span>
      <span class="card-title">Codifichiamo l'algoritmo</span>
      <span class="card-time">⏱ 20 min</span>
    </div>
    <div class="card-body">

      <div class="intro-box">
        Ora implementa il metodo di bisezione in Python. Parti dallo scheletro qui sotto
        e completa i punti indicati con <code style="color:var(--accent3)">???</code>.
      </div>

      <div class="code-block">
        <div class="code-label">bisezione.py — scheletro da completare</div>
        <pre><span class="kw">def</span> <span class="fn">bisezione</span>(<span class="var">f</span>, <span class="var">a</span>, <span class="var">b</span>, <span class="var">tol</span>=<span class="num">1e-6</span>, <span class="var">max_iter</span>=<span class="num">100</span>):
    <span class="st">"""
    Trova uno zero di f nell'intervallo [a, b].

    Parametri
    ---------
    f        : funzione continua su [a, b]
    a, b     : estremi dell'intervallo (f(a)*f(b) < 0)
    tol      : tolleranza sull'ampiezza dell'intervallo
    max_iter : numero massimo di iterazioni

    Ritorna
    -------
    (radice, n_iter) : approssimazione dello zero, iterazioni usate
    """</span>
    <span class="cm"># 1. Controlla che f(a) e f(b) abbiano segni opposti</span>
    <span class="kw">if</span> <span class="var">f</span>(<span class="var">a</span>) * <span class="var">f</span>(<span class="var">b</span>) <span class="op">>=</span> <span class="num">0</span>:
        <span class="kw">raise</span> <span class="fn">ValueError</span>(<span class="st">"f(a) e f(b) devono avere segni opposti"</span>)

    <span class="kw">for</span> <span class="var">i</span> <span class="kw">in</span> <span class="fn">range</span>(<span class="var">max_iter</span>):
        <span class="cm"># 2. Calcola il punto medio</span>
        <span class="var">m</span> = <span class="op">???</span>

        <span class="cm"># 3. Condizione di arresto</span>
        <span class="kw">if</span> (<span class="var">b</span> <span class="op">-</span> <span class="var">a</span>) <span class="op">/</span> <span class="num">2</span> <span class="op">&lt;</span> <span class="var">tol</span>:
            <span class="kw">return</span> <span class="var">m</span>, <span class="var">i</span>

        <span class="cm"># 4. Dimezza l'intervallo (quale metà contiene lo zero?)</span>
        <span class="kw">if</span> <span class="var">f</span>(<span class="var">a</span>) * <span class="var">f</span>(<span class="var">m</span>) <span class="op">&lt;</span> <span class="num">0</span>:
            <span class="var">b</span> = <span class="op">???</span>   <span class="cm"># lo zero è in [a, m]</span>
        <span class="kw">else</span>:
            <span class="var">a</span> = <span class="op">???</span>   <span class="cm"># lo zero è in [m, b]</span>

    <span class="kw">return</span> (<span class="var">a</span> <span class="op">+</span> <span class="var">b</span>) <span class="op">/</span> <span class="num">2</span>, <span class="var">max_iter</span>


<span class="cm"># ── Test ──────────────────────────────────────────────</span>
